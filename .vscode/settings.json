{
    // กำหนดความเชื่อมโยงของนามสกุลไฟล์เฉพาะทาง ให้ระบบประมวลผลเป็นไวยากรณ์ของภาษา C
    "files.associations": {
        "string.h": "c",
        "math.h": "c",
        "corecrt_math.h": "c",
        "*.hc": "c"
    },
    
    // ระงับการแสดงผลเส้นใต้สีแดง (แจ้งเตือนข้อผิดพลาด) ของส่วนขยาย C/C++ เพื่อลดการรบกวนสายตา
    "C_Cpp.errorSquiggles": "disabled",

    // [ส่วนเสริมเพื่อความสมดุล] บังคับให้เปิดและบันทึกไฟล์ในรูปแบบ UTF-8 เสมอ เพื่อป้องกันปัญหาการแสดงผลอักขระภาษาไทยผิดเพี้ยน
    "files.encoding": "utf8",

    // [ส่วนเสริมเพื่อความสมดุล] กำหนดระยะย่อหน้า (Tab) ให้มีขนาดเท่ากับ 4 ช่องว่าง เพื่อความสวยงามและเป็นระเบียบตามมาตรฐาน
    "editor.tabSize": 4
}
